# Copy this file to .env and fill in your real values.
# Never commit .env to git.

# OpenAI (legacy — used for fallback chat until Vertex retrieval is wired in)
OPENAI_API_KEY=sk-replace-with-your-real-key

# ---- Google Cloud / Vertex AI ----
# Path to your service account JSON, relative to the project root.
# Save the file at credentials/gcp-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-service-account.json

# Your GCP project ID
GCP_PROJECT_ID=scholr-dev

# Region for Vertex AI
GCP_LOCATION=us-central1
